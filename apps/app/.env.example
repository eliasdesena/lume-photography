# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# ── Mux (video delivery) ──
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_SIGNING_KEY_ID=your-signing-key-id
MUX_SIGNING_KEY_PRIVATE="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ── Brevo (optional — if sending emails from app) ──
BREVO_API_KEY=xkeysib-...

# ── Stripe (for refunds) ──
STRIPE_SECRET_KEY=sk_live_...

# ── Push Notifications (VAPID) ──
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:hello@lumephoto.co

# ── Cron (secure reminder endpoint) ──
CRON_SECRET=your-random-secret

# ── App ──
NEXT_PUBLIC_APP_URL=https://app.lumephoto.co
