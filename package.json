{
  "name": "lume",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "dev:web": "turbo dev --filter=@lume/web",
    "dev:app": "turbo dev --filter=@lume/app",
    "build:web": "turbo build --filter=@lume/web",
    "build:app": "turbo build --filter=@lume/app"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "packageManager": "npm@10.9.2"
}
